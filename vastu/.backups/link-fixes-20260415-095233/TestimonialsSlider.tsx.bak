'use client';
import { useSound } from '@/hooks/useSound';
import './TestimonialsSlider.css';

interface Testimonial {
  id?: string;
  client_name: string;
  location: string;
  content: string;
  rating?: number;
  gradient?: string;
}

const defaultTestimonials: Testimonial[] = [
  {
    client_name: 'Priya Malhotra',
    location: 'London, UK',
    content: "Acharya's guidance transformed our home. We've never felt such peace.",
    gradient: 'linear-gradient(135deg, #C88A5D 0%, #E8B960 100%)',
  },
  {
    client_name: 'James Whitmore',
    location: 'New York, USA',
    content: "The commercial Vastu analysis was spot on. Revenue up 40% in months.",
    gradient: 'linear-gradient(135deg, #1A2A3A 0%, #2D6A4F 100%)',
  },
  {
    client_name: 'Ananya Sharma',
    location: 'Dubai, UAE',
    content: "My health improved dramatically after implementing the remedies.",
    gradient: 'linear-gradient(135deg, #457B9D 0%, #C88A5D 100%)',
  },
  {
    client_name: 'Michael Chen',
    location: 'Singapore',
    content: "Unparalleled depth of knowledge. Practical and transformative.",
    gradient: 'linear-gradient(135deg, #2D6A4F 0%, #E8B960 100%)',
  },
  {
    client_name: 'Elena Rossi',
    location: 'Milan, Italy',
    content: "Finally feel at peace in my own home. Forever grateful.",
    gradient: 'linear-gradient(135deg, #C88A5D 0%, #1A2A3A 100%)',
  },
  {
    client_name: 'David Miller',
    location: 'Sydney, Australia',
    content: "The land selection advice saved us from a disastrous purchase.",
    gradient: 'linear-gradient(135deg, #E8B960 0%, #457B9D 100%)',
  },
  {
    client_name: 'Sophia Rodriguez',
    location: 'Madrid, Spain',
    content: "A true master of the ancient science. Highly recommended.",
    gradient: 'linear-gradient(135deg, #1A2A3A 0%, #C88A5D 100%)',
  },
  {
    client_name: 'Kenji Tanaka',
    location: 'Tokyo, Japan',
    content: "Our entire office feels more productive and harmonious.",
    gradient: 'linear-gradient(135deg, #2D6A4F 0%, #1A2A3A 100%)',
  },
  {
    client_name: 'Olivia Brown',
    location: 'Toronto, Canada',
    content: "The Vastu scan was incredibly detailed and accurate.",
    gradient: 'linear-gradient(135deg, #457B9D 0%, #2D6A4F 100%)',
  },
];

interface TestimonialsSliderProps {
  testimonials?: Testimonial[];
}

export function TestimonialsSlider({ testimonials }: TestimonialsSliderProps) {
  const { play } = useSound();
  const items = testimonials && testimonials.length > 0 ? testimonials : defaultTestimonials;

  // Assign default gradients if not provided
  const gradients = [
    'linear-gradient(135deg, #C88A5D 0%, #E8B960 100%)',
    'linear-gradient(135deg, #1A2A3A 0%, #2D6A4F 100%)',
    'linear-gradient(135deg, #457B9D 0%, #C88A5D 100%)',
    'linear-gradient(135deg, #2D6A4F 0%, #E8B960 100%)',
    'linear-gradient(135deg, #C88A5D 0%, #1A2A3A 100%)',
    'linear-gradient(135deg, #E8B960 0%, #457B9D 100%)',
    'linear-gradient(135deg, #1A2A3A 0%, #C88A5D 100%)',
    'linear-gradient(135deg, #2D6A4F 0%, #1A2A3A 100%)',
    'linear-gradient(135deg, #457B9D 0%, #2D6A4F 100%)',
  ];

  const enrichedItems = items.map((item, index) => ({
    ...item,
    gradient: item.gradient || gradients[index % gradients.length],
  }));

  return (
    <section className="py-24 bg-gradient-to-b from-[#F9F6F0] to-white overflow-hidden">
      <div className="container mx-auto px-6">
        <div className="text-center mb-16">
          <h2 className="font-serif text-4xl md:text-5xl text-[#1A2A3A] mb-4">
            Words of Gratitude
          </h2>
          <p className="font-sans text-lg text-[#1A2A3A]/60 max-w-2xl mx-auto">
            Hear from those who have experienced the transformation
          </p>
        </div>
      </div>

      <div
        className="slider"
        style={
          {
            '--width': '280px',
            '--height': '220px',
            '--quantity': enrichedItems.length.toString(),
          } as React.CSSProperties
        }
      >
        <div className="list">
          {enrichedItems.map((item, index) => (
            <div
              key={index}
              className="item"
              style={{ '--position': index + 1 } as React.CSSProperties}
              onMouseEnter={() => play('hoverCard')}
            >
              <div
                className="testimonial-slider-card"
                style={{ background: item.gradient }}
              >
                <div className="card-inner">
                  <div className="quote-mark">"</div>
                  <p className="testimonial-quote">{item.content}</p>
                  <div className="testimonial-author">
                    <span className="author-name">{item.client_name}</span>
                    <span className="author-location">{item.location}</span>
                  </div>
                </div>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>
  );
}
export default TestimonialsSlider;

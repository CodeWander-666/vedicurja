      <div className="container mx-auto px-6 text-center max-w-3xl">
        <AnimatedText text="Try a Free Lesson" className="font-serif text-4xl md:text-5xl mb-6 text-white" />
        <p className="text-xl text-white/80 mb-8">Watch a sample module on the Five Elements of Vastu.</p>
        {!showVideo ? (
          <button onClick={() => setShowVideo(true)} className="bg-prakash-gold hover:bg-sacred-saffron text-nidra-indigo font-bold px-10 py-5 rounded-full text-lg transition">
            Watch Free Lesson
          </button>
        ) : (
          <div className="aspect-video rounded-2xl overflow-hidden shadow-2xl">
            <video controls className="w-full h-full" src="/videos/placeholder.mp4" poster="/images/home/vastu-pattern.png" />

// ----------------------------------------------------------------------
// Section 12: Final CTA
// ----------------------------------------------------------------------
function FinalCTA() {
  return (
    <section className="relative py-32 bg-nidra-indigo text-white text-center overflow-hidden">
      <Mandala3D />
      <div className="container mx-auto px-6 relative z-10">
        <AnimatedText text="Begin Your Vastu Journey Today" className="font-serif text-4xl md:text-6xl mb-6 text-white" />
        <p className="text-xl text-white/80 max-w-3xl mx-auto mb-10">Enroll now and start learning from the master.</p>
        <Link href="/signup" className="bg-prakash-gold hover:bg-sacred-saffron text-nidra-indigo font-bold px-10 py-5 rounded-full text-lg transition">

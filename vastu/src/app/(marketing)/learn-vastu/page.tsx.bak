// ----------------------------------------------------------------------
// Section 8: Pricing Plans
// ----------------------------------------------------------------------
function PricingSection({ onSelect }: { onSelect: (price: number) => void }) {
  const plans = [
    { name: 'Self‑Paced', price: 9999, features: ['All modules', 'Lifetime access', 'Certificate'] },
    { name: 'Live Online', price: 14999, features: ['Live classes', 'Q&A sessions', 'Community access', 'Certificate'], popular: true },
  ];
  return (
    <section id="pricing" className="py-24 bg-vastu-stone/20">
      <div className="container mx-auto px-6">
        <AnimatedText text="Simple Pricing" className="font-serif text-4xl text-center text-nidra-indigo mb-4" />
        <p className="text-center text-nidra-indigo/60 mb-12">Choose the plan that fits your goals</p>
        <div className="grid md:grid-cols-2 gap-8 max-w-3xl mx-auto">
          {plans.map((p, i) => (
            <motion.div key={i} initial={{ opacity: 0, y: 20 }} whileInView={{ opacity: 1, y: 0 }} transition={{ delay: i * 0.1 }} className={`relative p-8 rounded-2xl ${p.popular ? 'bg-white shadow-xl border-2 border-prakash-gold' : 'bg-white/80 border border-prakash-gold/20'}`}>
              {p.popular && <span className="absolute -top-3 left-1/2 -translate-x-1/2 bg-sacred-saffron text-white px-4 py-1 rounded-full text-xs">Most Popular</span>}
              <h3 className="font-serif text-2xl mb-4">{p.name}</h3>
              <p className="text-4xl font-bold text-nidra-indigo">₹{p.price}</p>
              <ul className="my-6 space-y-2">
                {p.features.map((f, j) => <li key={j} className="flex items-center gap-2"><span className="text-prakash-gold">✓</span>{f}</li>)}
              </ul>
              <button onClick={() => onSelect(p.price)} className="w-full luxury-button">Enroll Now</button>
            </motion.div>
          ))}
        </div>
      </div>
    </section>
  );
}


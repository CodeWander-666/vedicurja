// ----------------------------------------------------------------------
// Main Page
// ----------------------------------------------------------------------
export default function LearnVastuPage() {
  const { user } = useAuth();
  const [showPayment, setShowPayment] = useState(false);
  const [selectedPrice, setSelectedPrice] = useState(0);

  const handleEnroll = (price: number) => {
    if (!user) {
      window.location.href = '/signin?redirect=/learn-vastu';
      return;
    }
    setSelectedPrice(price);
    setShowPayment(true);
  };

  const handlePaymentSuccess = async () => {
    // Simulate enrollment
    await supabase.from('payments').insert({ user_id: user?.id, amount: selectedPrice, tool: 'Vastu Course', status: 'simulated_success' });
    setShowPayment(false);
    window.location.href = '/dashboard/library';
  };

  return (
    <>
      <LuxuryCursor />
      <SoundController />
      <Header />
      <SmoothScroll>
        <main className="relative bg-vastu-parchment">
          <HeroSection />
          <WhyLearnSection />
          <MeetAcharyaSection />
          <CurriculumSection />
          <FormatsSection />
          <TestimonialsSection />
          <CertificationSection />
          <PricingSection onSelect={handleEnroll} />
          <FAQSection />
          <FreePreviewSection />
          <CommunitySection />
          <FinalCTA />
        </main>
        <Footer />
      </SmoothScroll>
      <PaymentSimulationModal isOpen={showPayment} onClose={() => setShowPayment(false)} tool="Vastu Course" amount={selectedPrice} onSuccess={handlePaymentSuccess} userId={user?.id} />
    </>
  );
}

  return (
    <section className="py-24 bg-white">
      <div className="container mx-auto px-6">
        <AnimatedText text="Why Learn Vastu?" className="font-serif text-4xl text-center text-nidra-indigo mb-16" />
        <div className="grid md:grid-cols-3 gap-8 max-w-5xl mx-auto">
          {benefits.map((b, i) => (
            <motion.div key={i} initial={{ opacity: 0, y: 20 }} whileInView={{ opacity: 1, y: 0 }} transition={{ delay: i * 0.1 }} whileHover={{ y: -5, rotateY: 3 }} style={{ transformStyle: 'preserve-3d' }} className="bg-vastu-stone/20 p-8 rounded-2xl text-center border border-prakash-gold/20">
              <div className="text-5xl mb-4">{b.icon}</div>
              <h3 className="font-serif text-xl mb-2">{b.title}</h3>
              <p className="text-sm text-nidra-indigo/60">{b.desc}</p>
            </motion.div>
          ))}
        </div>
      </div>
    </section>
  );
}


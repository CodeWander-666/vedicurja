// ----------------------------------------------------------------------
// Section 4: Curriculum Overview
// ----------------------------------------------------------------------
function CurriculumSection() {
  const modules = [
    { title: 'Foundations of Vastu', lessons: 8, topics: ['Five Elements', 'Directions', 'Vastu Purusha Mandala'] },
    { title: 'Residential Vastu', lessons: 12, topics: ['Room Placement', 'Entrance', 'Remedies'] },
    { title: 'Commercial Vastu', lessons: 10, topics: ['Office Layout', 'Cash Counter', 'Factory Vastu'] },
    { title: 'Advanced Remedies', lessons: 6, topics: ['Yantras', 'Pyramids', 'Crystals'] },
  ];
  return (
    <section id="curriculum" className="py-24 bg-vastu-stone/20">
      <div className="container mx-auto px-6">
        <AnimatedText text="What You'll Learn" className="font-serif text-4xl text-center text-nidra-indigo mb-16" />
        <div className="grid md:grid-cols-2 lg:grid-cols-4 gap-6 max-w-6xl mx-auto">
          {modules.map((m, i) => (
            <motion.div key={i} initial={{ opacity: 0, y: 20 }} whileInView={{ opacity: 1, y: 0 }} transition={{ delay: i * 0.1 }} className="bg-white p-6 rounded-2xl shadow-md border border-prakash-gold/20">
              <h3 className="font-serif text-xl mb-2">{m.title}</h3>
              <p className="text-sm text-prakash-gold mb-3">{m.lessons} lessons</p>
              <ul className="space-y-1 text-sm text-nidra-indigo/70">
                {m.topics.map((t, j) => <li key={j}>• {t}</li>)}
              </ul>
            </motion.div>
          ))}
        </div>
      </div>
    </section>
  );
}

